# =============================================================================
# .env.example — Environment variable template for WLASL300 Sign Language
# =============================================================================
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your values below
#   3. Never commit .env — it is listed in .gitignore
#
# Variables defined here are loaded automatically by python-dotenv when you
# call load_dotenv() in your scripts, or by your shell if you run:
#   export $(grep -v '^#' .env | xargs)
# =============================================================================


# -----------------------------------------------------------------------------
# Weights & Biases (W&B) — optional experiment tracker
# -----------------------------------------------------------------------------
# Required only if you pass --logger wandb to train.py.
# Get your API key at: https://wandb.ai/authorize

WANDB_API_KEY=your_wandb_api_key_here      # 40-character hex string from wandb.ai
WANDB_PROJECT=wlasl300-sign-language       # Name of the W&B project to log runs under
WANDB_ENTITY=your_wandb_username_or_team  # Your W&B username or team name


# -----------------------------------------------------------------------------
# MLflow — optional experiment tracker (self-hosted)
# -----------------------------------------------------------------------------
# Required only if you pass --logger mlflow to train.py.
# Start the local UI with:  uv run mlflow ui --port 5000

MLFLOW_TRACKING_URI=http://localhost:5000  # URI of your MLflow tracking server
                                           # Use a remote URI for shared team tracking
                                           # e.g. http://my-server.com:5000


# -----------------------------------------------------------------------------
# Kaggle — dataset download credentials
# -----------------------------------------------------------------------------
# Required to run: kaggle datasets download vodinhnhattruong/dataset-wlasl300
# Find your credentials at: https://www.kaggle.com/settings → API → Create Token
# This downloads a kaggle.json — copy the values below from that file.

KAGGLE_USERNAME=your_kaggle_username       # Your Kaggle account username
KAGGLE_KEY=your_kaggle_api_key            # 32-character API key from kaggle.json


# -----------------------------------------------------------------------------
# Dataset paths — override the defaults set in config/config.yaml
# -----------------------------------------------------------------------------
# These are optional. If unset, the values in config.yaml are used instead.
# Set them here if your data lives outside the project directory, e.g. on a
# shared NFS mount, an external SSD, or a Google Drive mount on Colab.

WLASL_RAW_DIR=/path/to/data/raw           # Root dir of the Kaggle download.
                                           # Expected layout: one folder per word,
                                           # each containing .mp4 video files.

                                           # Download from:
                                           # Contains per-video signer ID, bounding box,
                                           # frame start/end, and original split assignments.

WORD2VEC_BIN_PATH=/path/to/GoogleNews-vectors-negative300.bin
                                           # Path to the pretrained Google News Word2Vec binary.
                                           # ~1.5 GB download from:
                                           # drive.google.com/file/d/0B7XkCwpI5KDYNlNUTTlSS21pQmM
                                           # Used by build_annotations.py to generate
                                           # word2vec_embeddings.npy for all 300 class words.


# -----------------------------------------------------------------------------
# Hardware — GPU selection
# -----------------------------------------------------------------------------
# Controls which GPU(s) PyTorch can see. Must be set before the Python process
# starts — changing it at runtime has no effect.
#
# Examples:
#   CUDA_VISIBLE_DEVICES=0        → use GPU 0 only (recommended for single-GPU)
#   CUDA_VISIBLE_DEVICES=0,1      → use GPUs 0 and 1 (multi-GPU / DDP)
#   CUDA_VISIBLE_DEVICES=""       → CPU-only mode (slow, for debugging only)

CUDA_VISIBLE_DEVICES=0
